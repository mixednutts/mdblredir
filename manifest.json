{
  "manifest_version": 3,
  "name": "mdblredir",
  "version": "1.0.0",
  "description": "Redirect media links (IMDB, SIMKL, TMDB, TVDB, etc.) to the equivalent MDBLIST page.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.imdb.com/*",
    "*://*.themoviedb.org/*",
    "*://*.tvdb.com/*",
    "*://*.simkl.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
