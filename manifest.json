{
  "manifest_version": 3,
  "name": "MDBList Redirector",
  "version": "1.4.0",
  "description": "Redirect media links (IMDB, Trakt, TMDB, TVDB, SIMKL) to the equivalent MDBLIST page.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*.imdb.com/*",
    "*://*.trakt.tv/*",
    "*://*.themoviedb.org/*",
    "*://*.thetvdb.com/*",
    "*://*.simkl.com/*",
    "*://*.mdblist.com/*",
    "*://api.mdblist.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
