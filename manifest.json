{
  "manifest_version": 3,
  "name": "mdblredir",
  "version": "1.1.0",
  "description": "Redirect media links (IMDB, etc.) to the equivalent MDBLIST page.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "*://*.imdb.com/*",
    "*://*.mdblist.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
